    },
    "relation_description": {
      "type": "string",
      "required": true,
      "maxLength": 64
    },
    "relations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::relation.relation",
      "mappedBy": "relation_type"
    }
  }

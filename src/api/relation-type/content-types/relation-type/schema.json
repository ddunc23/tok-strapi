{
  "kind": "collectionType",
  "collectionName": "relation_types",
  "info": {
    "singularName": "relation-type",
    "pluralName": "relation-types",
    "displayName": "Relation Type",
    "description": "Types of relationships between makers"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
